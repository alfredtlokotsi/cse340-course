<%- include('partials/header') %>

<main>
    <div class="page-header">
        <h1>🏷️ Service Project Categories</h1>
        <p>Browse projects by category</p>
    </div>

    <% if (categories && categories.length > 0) { %>
        <div class="categories-grid">
            <% categories.forEach(category => { %>
                <div class="category-card">
                    <h2><%= category.name %></h2>
                    <p><%= category.description || 'No description available' %></p>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p style="text-align: center; color: var(--gray-500); padding: var(--spacing-xl);">
            No categories found. Please run the setup.sql script to populate the database.
        </p>
    <% } %>
</main>

<%- include('partials/footer') %>