<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <% if (projects && projects.length > 0) { %>
        <p>Here are our current service projects:</p>
        <ul class="project-list">
            <% projects.forEach(project => { %>
                <li>
                    <h2><%= project.title %></h2>
                    <p><strong>Organization:</strong> <%= project.organization_name %></p>
                    <p><strong>Description:</strong> <%= project.description || 'No description available' %></p>
                    <p><strong>Location:</strong> <%= project.location || 'TBD' %></p>
                    <p><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric' 
                    }) %></p>
                    <p><strong>Status:</strong> 
                        <span class="status-badge status-<%= project.status %>">
                            <%= project.status.charAt(0).toUpperCase() + project.status.slice(1) %>
                        </span>
                    </p>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No projects found. Please run the setup.sql script to populate the database.</p>
    <% } %>
</main>

<%- include('partials/footer') %>