<%- include('partials/header') %>

<main>
    <div class="page-header">
        <h1>📁 Service Projects</h1>
        <p>Current service opportunities with our partner organizations</p>
    </div>

    <% if (projects && projects.length > 0) { %>
        <div class="projects-grid">
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <h2><%= project.title %></h2>
                    
                    <div class="project-meta">
                        <span><strong>Organization:</strong> <%= project.organization_name %></span>
                        <span><strong>Location:</strong> <%= project.location || 'TBD' %></span>
                        <span><strong>Date:</strong> <%= new Date(project.project_date).toLocaleDateString('en-US', { 
                            year: 'numeric', 
                            month: 'short', 
                            day: 'numeric' 
                        }) %></span>
                    </div>
                    
                    <p class="project-description"><%= project.description || 'No description available' %></p>
                    
                    <span class="project-status status-<%= project.status %>">
                        <%= project.status.charAt(0).toUpperCase() + project.status.slice(1) %>
                    </span>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p style="text-align: center; color: var(--gray-500); padding: var(--spacing-xl);">
            No projects found. Please run the setup.sql script to populate the database.
        </p>
    <% } %>
</main>

<%- include('partials/footer') %>