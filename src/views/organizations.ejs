<%- include('partials/header') %>

<main>
    <div class="page-header">
        <h1>🤝 Our Partner Organizations</h1>
        <p>These organizations are making a difference in our community</p>
    </div>

    <% if (organizations && organizations.length > 0) { %>
        <div class="organization-grid">
            <% organizations.forEach(org => { %>
                <div class="organization-card">
                    <img class="organization-logo" 
                         src="/images/<%= org.logo_filename %>" 
                         alt="<%= org.name %> logo" 
                         onerror="this.style.display='none'">
                    <div class="organization-info">
                        <h2><%= org.name %></h2>
                        <p><%= org.description %></p>
                        <a href="mailto:<%= org.contact_email %>" class="organization-email">
                            ✉️ <%= org.contact_email %>
                        </a>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p style="text-align: center; color: var(--gray-500); padding: var(--spacing-xl);">
            No organizations found. Please run the setup.sql script to populate the database.
        </p>
    <% } %>
</main>

<%- include('partials/footer') %>