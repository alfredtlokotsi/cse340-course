<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <% if (organizations && organizations.length > 0) { %>
        <p>Here are our partner organizations:</p>
        <ul class="organization-list">
            <% organizations.forEach(org => { %>
                <li>
                    <img src="/images/<%= org.logo_filename %>" 
                         alt="<%= org.name %> logo" 
                         onerror="this.style.display='none'">
                    <div>
                        <h2><%= org.name %></h2>
                        <p><%= org.description %></p>
                        <p><strong>Contact:</strong> 
                            <a href="mailto:<%= org.contact_email %>">
                                <%= org.contact_email %>
                            </a>
                        </p>
                    </div>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No organizations found. Please run the setup.sql script to populate the database.</p>
    <% } %>
</main>

<%- include('partials/footer') %>